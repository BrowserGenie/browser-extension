  },
  "dependencies": {
    "axe-core": "^4.10.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0"
  }
}
